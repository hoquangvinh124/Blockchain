# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.

# From Alchemy: https://dashboard.alchemy.com/
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Your MetaMask wallet private key (export from MetaMask > Account Details)
# Use a dedicated testnet-only wallet, never your main wallet
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# From Etherscan: https://etherscan.io/myapikey (for contract verification)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Set after deployment - copy the printed contract address here, frontend uses it
CONTRACT_ADDRESS=
